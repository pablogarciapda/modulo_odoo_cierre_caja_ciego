<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_config_view_form_inherit_blind_closing" model="ir.ui.view">
        <field name="name">pos.config.form.inherit.blind.closing</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_posbox']/ancestor::setting" position="after">
                <setting string="Cierre de Caja Ciego" help="Activa el cierre de caja ciego para este punto de venta.">
                    <field name="l10n_es_blind_cash_closing"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
