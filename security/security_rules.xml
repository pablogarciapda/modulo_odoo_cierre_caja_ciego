<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_pos_blind_closing" model="ir.module.category">
            <field name="name">Cierre de Caja Ciego</field>
            <field name="description">Permisos para el módulo de Cierre de Caja Ciego.</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_pos_blind_closing_manager" model="res.groups">
            <field name="name">Manager de Cierre Ciego / Ver Totales</field>
            <field name="implied_ids" eval="[(4, ref('point_of_sale.group_pos_manager'))]"/>
            <field name="comment">
                Este grupo permite al usuario ver los importes esperados y las diferencias
                durante el proceso de cierre de caja ciego en el TPV. Hereda los permisos del
                Manager del TPV.
            </field>
        </record>
    </data>
</odoo>
